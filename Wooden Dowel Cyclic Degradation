for ni=1:4
    writecell(notes2(ni),EXCEL_OUT,'Sheet',SHT2,'Range',sprintf('A%d',21+ni));
end

% SHEET 3: Stiffness Degradation
SHT3 = 'Stiffness Degradation';
writecell({'Wooden Dowel Connections — Initial Stiffness Degradation Across Cycles'}, ...
    EXCEL_OUT,'Sheet',SHT3,'Range','A1');
