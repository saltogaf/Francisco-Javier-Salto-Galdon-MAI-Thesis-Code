        round(allEnd(i),3), round(allCumS(i),3), ...
        addSlip, round(allMax(i),3), round(allEla(i),3), elPct};
    writecell(row,EXCEL_OUT,'Sheet',SHT2,'Range',sprintf('A%d',4+i));
