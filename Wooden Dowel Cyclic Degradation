        round(allMax(i),3), round(allEnd(i),3), round(allEla(i),3)};
    writecell(row,EXCEL_OUT,'Sheet',SHT1,'Range',sprintf('A%d',5+i));
end

notes1 = {'Notes:', ...
    '1. 40% level = first cyclic peak (target 1.238 kN). Displacement here reflects connection slip at first major load event.', ...
    '2. 10% level = cyclic trough. Displacement here represents residual slip at the minimum load point within the cycle.', ...
    '3. 70% level = global load maximum within the run. Peak structural demand on the connection.', ...
    '4. Per-run residual = mean displacement of final 50 data points; represents permanent set from that run.'};
for ni=1:5
    writecell(notes1(ni),EXCEL_OUT,'Sheet',SHT1,'Range',sprintf('A%d',16+ni));
end

% SHEET 2: Cumulative Permanent Slip
SHT2 = 'Cumulative Permanent Slip';
writecell({'Wooden Dowel Connections — Cumulative Permanent Slip Analysis'}, ...
    EXCEL_OUT,'Sheet',SHT2,'Range','A1');
writecell({'Cumulative slip = running total of per-run residuals since first assembly. Represents total irreversible deformation of the timber hole.'}, ...
    EXCEL_OUT,'Sheet',SHT2,'Range','A2');

hdrs2 = {'Sample','Run', ...
    'Per-Run Residual (mm)','Cumulative Slip (mm)', ...
    'Additional Slip vs Previous Run (mm)', ...
    'Max Displacement (mm)','Elastic Recovery (mm)','Elastic Recovery as % of Max'};
writecell(hdrs2,EXCEL_OUT,'Sheet',SHT2,'Range','A4');

for i = 1:9
    if strcmp(cycRuns{i},'Run 1 (Initial)')
