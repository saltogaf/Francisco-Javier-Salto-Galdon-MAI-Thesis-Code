    'Per-Run Residual (mm)','Elastic Recovery (mm)','Recovery as % of Max'};
writecell(hdrs4,EXCEL_OUT,'Sheet',SHT4,'Range','A4');

for i=1:9
    elPct = round(allEla(i)/allMax(i)*100,1);
    row   = {cycSamples{i},cycRuns{i}, ...
        round(allMax(i),3),round(allEnd(i),3),round(allEla(i),3),elPct};
