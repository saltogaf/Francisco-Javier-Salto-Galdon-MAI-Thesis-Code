              'Run 1 (Initial)','Run 2','Retest'};
% Unroll DISP into indexed arrays
allD40 =[DISP.S4.disp40,  DISP.S5.disp40,  DISP.S6.disp40];
allD10 =[DISP.S4.disp10,  DISP.S5.disp10,  DISP.S6.disp10];
allD70 =[DISP.S4.disp70,  DISP.S5.disp70,  DISP.S6.disp70];
allMax =[DISP.S4.dispMax, DISP.S5.dispMax, DISP.S6.dispMax];
allEnd =[DISP.S4.dispEnd, DISP.S5.dispEnd, DISP.S6.dispEnd];
allEla =[DISP.S4.elasticRec, DISP.S5.elasticRec, DISP.S6.elasticRec];
allStf =[DISP.S4.stiff,  DISP.S5.stiff,  DISP.S6.stiff];
allCumS=[DISP.S4.cumSlip,DISP.S5.cumSlip,DISP.S6.cumSlip];

% Reorder: S4 runs 1-3, S5 runs 1-3, S6 runs 1-3 (already in order)
idx = 1:9; 

% SHEET 1: Displacements at Key Load Levels
SHT1 = 'Displacements at Load Levels';
writecell({'Wooden Dowel Connections — Displacement at Eurocode Load Levels'}, ...
    EXCEL_OUT,'Sheet',SHT1,'Range','A1');
writecell({sprintf('EC5 = %.4f kN  |  40%% target = %.4f kN  |  10%% target = %.4f kN  |  70%% target = %.4f kN', ...
    EC5,T40,T10,T70)},EXCEL_OUT,'Sheet',SHT1,'Range','A2');
writecell({'All displacements are zero-referenced to the start of each individual run. Actual detected load at each level may differ slightly from target.'}, ...
    EXCEL_OUT,'Sheet',SHT1,'Range','A3');

hdrs1 = {'Sample','Run', ...
    'Disp. at 40% (mm)','Actual Load at 40% (kN)', ...
    'Disp. at 10% (mm)', ...
    'Disp. at 70% (mm)','Actual Load at 70% (kN)', ...
    'Max Displacement (mm)','Per-Run Residual (mm)','Elastic Recovery (mm)'};
writecell(hdrs1,EXCEL_OUT,'Sheet',SHT1,'Range','A5');

for i = 1:9
    row = {cycSamples{i}, cycRuns{i}, ...
        round(allD40(i),3), round(KD.(fields{i}).load40,3), ...
        round(allD10(i),3), ...
